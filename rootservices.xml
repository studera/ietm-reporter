<rdf:Description
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:dc="http://purl.org/dc/terms/"
     xmlns:jfs="http://jazz.net/xmlns/prod/jazz/jfs/1.0/" 
     xmlns:jtp="http://jazz.net/xmlns/prod/jazz/jtp/0.6/"
     xmlns:jd="http://jazz.net/xmlns/prod/jazz/discovery/1.0/" 
     xmlns:jp06="http://jazz.net/xmlns/prod/jazz/process/0.6/"
     xmlns:ju="http://jazz.net/ns/ui#"
	 xmlns:jdb="http://jazz.net/xmlns/prod/jazz/dashboard/1.0/"
     xmlns:rqm="http://jazz.net/xmlns/prod/jazz/rqm/qm/1.0/"
     xmlns:qm_rqm="http://jazz.net/ns/qm/rqm#"
     xmlns:oslc="http://open-services.net/ns/core#"
     xmlns:trs="http://jazz.net/ns/trs#" 
     xmlns:trs2="http://open-services.net/ns/core/trs#"    
     rdf:about="https://jazz.net/sandbox01-qm/rootservices">

  <!-- 
  		Default root service registry document for an RQM server.
  		Contains contributions for core JFS services and components
  		and OSLC Quality Management.
  		Specification is available at https://jazz.net/wiki/bin/view/Main/RootServicesSpec
   -->

  <!-- Add descriptive title here -->
  <dc:title xml:lang="en">Quality Management</dc:title>

  <!-- List of friends (applications known to this application) -->
  <jd:friends
      xmlns:jd="http://jazz.net/xmlns/prod/jazz/discovery/1.0/" 
      rdf:resource="https://jazz.net/sandbox01-qm/friends" />
       
  <!-- Viewlet-related properties -->
  <jd:viewletServiceRoot
  	  rdf:resource="https://jazz.net/sandbox01-qm" />

  <jd:viewletWebUIRoot
  	  rdf:resource="https://jazz.net/sandbox01-qm" />

  <!-- Default root service registry document for a JFS server. -->

  <jd:jsaSsoEnabled>false</jd:jsaSsoEnabled>
  
  <jfs:oauthRequestTokenUrl
  	  rdf:resource="https://jazz.net/sandbox01-qm/oauth-request-token" />
  
  <jfs:oauthAccessTokenUrl
  	  rdf:resource="https://jazz.net/sandbox01-qm/oauth-access-token" />
  	  
  <jfs:oauthRealmName>Jazz</jfs:oauthRealmName>
  <jfs:oauthDomain>https://jazz.net/sandbox01-qm</jfs:oauthDomain>
  	  
  <jfs:oauthUserAuthorizationUrl
  	  rdf:resource="https://jazz.net/sandbox01-qm/oauth-authorize" />
  	  
  <jfs:oauthRequestConsumerKeyUrl
      rdf:resource="https://jazz.net/sandbox01-qm/oauth-request-consumer" />
  
  <!-- JAuth URLS -->
  
  <jfs:jauthCheckAuthUrl rdf:resource="https://jazz.net/sandbox01-qm/jauth-check-auth"/>
  
  <!-- service for finding users and getting user info -->
  <jfs:users
  	  rdf:resource="https://jazz.net/sandbox01-jts/users"   />
  
  <!-- Service to redirect to the resource that represents the authenticated user -->
  <jfs:currentUser
  	  rdf:resource="https://jazz.net/sandbox01-qm/whoami"   />
  	  
  <!-- JFS storage service --> 
  <jfs:storage
  	  rdf:resource="https://jazz.net/sandbox01-qm/storage"   />
  
  <!-- JFS SPARQL query service -->
  <jfs:query
  	  rdf:resource="https://jazz.net/sandbox01-qm/query"   />

  <!-- Put RQM changes in here, so we do not have to merge all the time : START -->

  <!-- Quality Management services catalog -->
  <oslc_qm:qmServiceProviders
	      xmlns:oslc_qm="http://open-services.net/xmlns/qm/1.0/"
	      rdf:resource="https://jazz.net/sandbox01-qm/oslc_qm/catalog" />

  <!-- Quality Management Test Automation services catalog -->
  <oslc_auto:autoServiceProviders
	      xmlns:oslc_auto="http://open-services.net/ns/auto#"
	      rdf:resource="https://jazz.net/sandbox01-qm/oslc_auto_test/catalog" />
  
  <!-- RQM Resources (TRS 2.0) -->
  <qm_rqm:trackedResourceSetProvider>
    <trs2:TrackedResourceSet>
	  <trs2:trackedResourceSet rdf:resource="https://jazz.net/sandbox01-qm/trs2" />
	  <oslc:domain rdf:resource="http://open-services.net/ns/config#" />
	  <dc:title xml:lang="en">ETM Resources (TRS 2.0)</dc:title>
      <dc:description xml:lang="en">IBM Engineering Test Management (QM) resources, including test plans, cases, scripts, and results.</dc:description>
      <dc:type rdf:resource="http://open-services.net/ns/qm#" /> 
	</trs2:TrackedResourceSet>
  </qm_rqm:trackedResourceSetProvider>
  
  <!-- RQM Process Resources (TRS 2.0) -->
  <qm_rqm:trackedResourceSetProvider>
    <trs2:TrackedResourceSet>
	  <trs2:trackedResourceSet rdf:resource="https://jazz.net/sandbox01-qm/process-trs2" />
	  <dc:title xml:lang="en">ETM Process Resources (TRS 2.0)</dc:title>
      <dc:description xml:lang="en">IBM Engineering Test Management (QM) process resources, including project areas, team areas, timelines, and iterations.</dc:description>
      <dc:type rdf:resource="http://jazz.net/ns/process#" />
	</trs2:TrackedResourceSet>
  </qm_rqm:trackedResourceSetProvider>

  <!-- Server Rename Status -->
  <jfs:serverRenameStatus
      rdf:resource="https://jazz.net/sandbox01-qm/appServerRenameStatus" />

  <!-- Put RQM changes in here, so we do not have to merge all the time : END -->
  
  <!-- Change Management service catalog -->
  <!-- Deprecate QM as Change Management service provider starting from QM 6.0, see WI135518  -->
  <!-- 
  <oslc_cm:cmServiceProviders
          xmlns:oslc_cm="http://open-services.net/xmlns/cm/1.0/"
          rdf:resource="https://jazz.net/sandbox01-qm/oslc/workitems/catalog" />
  -->

  <!-- Configuration Management service catalog -->
  <oslc_config:cmServiceProviders
          xmlns:oslc_config="http://open-services.net/ns/config#"
          rdf:resource="https://jazz.net/sandbox01-qm/oslc_config/catalog"  />

  <!-- Widget Catalog service icon (provisional) -->     
  <ju:widgetCatalog 
      rdf:resource="https://jazz.net/sandbox01-qm/jfs/WidgetCatalog"/>  

  <!-- JFS indexing service --> 
  <jfs:indexing
  	  rdf:resource="https://jazz.net/sandbox01-qm/indexing"   />
  	  
  <!-- JFS revisions and history of storage resources -->  	  
  <jfs:history
  	  rdf:resource="https://jazz.net/sandbox01-qm/history"   />
  
  <!-- JFS full text search -->
  <jfs:search
  	  rdf:resource="https://jazz.net/sandbox01-qm/search"   />

  <!-- JFS baseline service --> 
  <jfs:baselines
  	  rdf:resource="https://jazz.net/sandbox01-qm/baselines"   />
  	  
  <!-- JFS mailer service --> 
  <jfs:mailer
  	  rdf:resource="https://jazz.net/sandbox01-qm/mailer"   />  	 
  	   
  <!-- Project areas service. This service is provisional and may change in the next release. -->
  <jp06:projectAreas
  	  rdf:resource="https://jazz.net/sandbox01-qm/process/project-areas" />
  	    	  
  <!-- Process templates service. This service is provisional and may change in the next release. -->
  <jp06:processTemplates
  	  rdf:resource="https://jazz.net/sandbox01-qm/process/templates" />

  <!-- Process security service. This service is provisional and may change in the next release. -->
  <jp06:processSecurity 
      rdf:resource="https://jazz.net/sandbox01-qm/process-security"/>
  	  
  <jd:infocenterRoot
  	  rdf:resource="https://jazz.net/sandbox01-qm/clmhelp" />

  <rqm:majorVersion>7</rqm:majorVersion>
  <rqm:version>7.2</rqm:version>
  
  <!-- CLM automated setup -->
  <jd:registration
     rdf:resource="https://jazz.net/sandbox01-qm/service/com.ibm.team.repository.service.internal.setup.IRegistrationHandlerService" />
     
  <jfs:setupWizardDescriptor
     rdf:resource="https://jazz.net/sandbox01-qm/service/com.ibm.team.repository.service.internal.setup.ISetupWizardDescriptorService"/>
     
  <jfs:adminWebUI rdf:resource="https://jazz.net/sandbox01-qm/admin"/>
  
 
<!-- Discovery service for the JFS server and associated applications -->
  <jd:discovery
      rdf:resource="https://jazz.net/sandbox01-qm/discovery" />
  	  
  <!-- JFS revisions and history of storage resources -->  	  	 
  
    <!-- JFS bulk operations service --> 
  <jfs:bulkOperations
  	  rdf:resource="https://jazz.net/sandbox01-qm/bulk"   />
  
  <!-- JFS changes service -->
  <jfs:changes
      rdf:resource="https://jazz.net/sandbox01-qm/changes" />
  
  <!--  Allow remote oauth consumer key authorization -->    
  <jfs:oauthApprovalModuleUrl
      rdf:resource="https://jazz.net/sandbox01-qm/_ajax-modules/com.ibm.team.repository.AuthorizeOAuth" />
  
  <!-- Dashboards service (provisional) -->
  <jdb:dashboards
  	  rdf:resource="https://jazz.net/sandbox01-qm/dashboards" /> 
  
  <!--  Application About service -->	  
  <oslc:publisher rdf:resource="https://jazz.net/sandbox01-qm/application-about"/>
  
  <jtp:associations							rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/associations"/>
  <jtp:defaultPracticeLibraryUrl			rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/libraries/shared"/>
  <jtp:file									rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/file"/>
  <jtp:license								rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/license"/>
  <jtp:practices							rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/practices"/>
  <jtp:processDescriptions					rdf:resource="https://jazz.net/sandbox01-qm/process-authoring/descriptions"/>
  	  
</rdf:Description>