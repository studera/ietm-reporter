{
  "name": "ietm-playwright-client",
  "version": "1.0.0",
  "description": "IBM Engineering Test Management client for reporting Playwright test results",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-resources",
    "copy-resources": "node -e \"const fs=require('fs'); const path=require('path'); const src='src/resources'; const dest='dist/src/resources'; if(!fs.existsSync(dest)){fs.mkdirSync(dest,{recursive:true})} fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)))\"",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ietm",
    "ibm",
    "engineering",
    "test",
    "management",
    "playwright",
    "testing",
    "automation",
    "oslc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "axios": "^1.6.2",
    "axios-cookiejar-support": "^4.0.7",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fast-xml-parser": "^4.3.2",
    "form-data": "^4.0.0",
    "js-yaml": "^4.1.0",
    "tough-cookie": "^4.1.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/axios-mock-adapter": "^1.9.0",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.10.5",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
