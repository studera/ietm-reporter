{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IETM Playwright Client Configuration",
  "description": "Configuration schema for IETM Playwright integration",
  "type": "object",
  "required": ["server", "auth"],
  "properties": {
    "server": {
      "type": "object",
      "description": "Server configuration",
      "required": ["baseUrl"],
      "properties": {
        "baseUrl": {
          "type": "string",
          "description": "Base URL of the IETM server",
          "format": "uri"
        },
        "jtsUrl": {
          "type": "string",
          "description": "JTS (Jazz Team Server) URL",
          "format": "uri"
        },
        "projectId": {
          "type": "string",
          "description": "Project ID"
        },
        "projectName": {
          "type": "string",
          "description": "Project name"
        },
        "contextId": {
          "type": "string",
          "description": "Context ID"
        },
        "autoDiscoverIds": {
          "type": "boolean",
          "description": "Automatically discover project and context IDs",
          "default": false
        }
      }
    },
    "auth": {
      "type": "object",
      "description": "Authentication configuration",
      "oneOf": [
        {
          "properties": {
            "type": {
              "type": "string",
              "const": "basic"
            },
            "username": {
              "type": "string",
              "description": "Username for basic authentication"
            },
            "password": {
              "type": "string",
              "description": "Password for basic authentication"
            }
          },
          "required": ["type", "username", "password"]
        },
        {
          "properties": {
            "type": {
              "type": "string",
              "const": "oauth"
            },
            "consumerKey": {
              "type": "string",
              "description": "OAuth consumer key"
            },
            "consumerSecret": {
              "type": "string",
              "description": "OAuth consumer secret"
            },
            "accessToken": {
              "type": "string",
              "description": "OAuth access token"
            },
            "accessTokenSecret": {
              "type": "string",
              "description": "OAuth access token secret"
            }
          },
          "required": ["consumerKey", "consumerSecret", "accessToken", "accessTokenSecret"]
        }
      ]
    },
    "testPlan": {
      "type": "object",
      "description": "Test plan configuration",
      "properties": {
        "id": {
          "type": "string",
          "description": "Test plan ID"
        },
        "name": {
          "type": "string",
          "description": "Test plan name"
        }
      }
    },
    "mapping": {
      "type": "object",
      "description": "Test case mapping configuration",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["title", "id", "tag"],
          "description": "Mapping strategy to use"
        },
        "annotationType": {
          "type": "string",
          "description": "Annotation type for test case mapping"
        },
        "mappings": {
          "type": "object",
          "description": "Manual test case mappings",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "retry": {
      "type": "object",
      "description": "Retry configuration",
      "properties": {
        "maxRetries": {
          "type": "integer",
          "description": "Maximum number of retries",
          "minimum": 0,
          "default": 3
        },
        "retryDelay": {
          "type": "integer",
          "description": "Delay between retries in milliseconds",
          "minimum": 0,
          "default": 1000
        },
        "backoffMultiplier": {
          "type": "number",
          "description": "Multiplier for exponential backoff",
          "minimum": 1,
          "default": 2
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["error", "warn", "info", "debug", "trace"],
          "description": "Logging level",
          "default": "info"
        },
        "file": {
          "type": "string",
          "description": "Log file path"
        },
        "console": {
          "type": "boolean",
          "description": "Enable console logging",
          "default": true
        },
        "maxFiles": {
          "type": "integer",
          "description": "Maximum number of log files to keep",
          "minimum": 1,
          "default": 7
        },
        "maxSize": {
          "type": "string",
          "description": "Maximum size of each log file (e.g., '10m', '1g')",
          "pattern": "^\\d+[kmg]$"
        }
      }
    },
    "attachments": {
      "type": "object",
      "description": "Attachment configuration",
      "properties": {
        "uploadScreenshots": {
          "type": "boolean",
          "description": "Upload screenshots",
          "default": true
        },
        "uploadVideos": {
          "type": "boolean",
          "description": "Upload videos",
          "default": true
        },
        "uploadLogs": {
          "type": "boolean",
          "description": "Upload logs",
          "default": true
        },
        "maxFileSize": {
          "type": "integer",
          "description": "Maximum file size in bytes",
          "minimum": 0,
          "default": 10485760
        },
        "compressImages": {
          "type": "boolean",
          "description": "Compress images before upload",
          "default": true
        }
      }
    },
    "reporting": {
      "type": "object",
      "description": "Reporting configuration",
      "properties": {
        "batchSize": {
          "type": "integer",
          "description": "Number of results to batch together",
          "minimum": 1,
          "default": 10
        },
        "reportOnlyMappedTests": {
          "type": "boolean",
          "description": "Only report tests that have mappings",
          "default": true
        },
        "createExecutionRecords": {
          "type": "boolean",
          "description": "Create execution records",
          "default": true
        },
        "updateExistingResults": {
          "type": "boolean",
          "description": "Update existing test results",
          "default": false
        }
      }
    }
  }
}