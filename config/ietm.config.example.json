{
  "$schema": "./ietm.config.schema.json",
  "server": {
    "baseUrl": "https://jazz.net/sandbox01-qm",
    "jtsUrl": "https://jazz.net/sandbox01-jts",
    "projectName": "Your Project Name",
    "autoDiscoverIds": true
  },
  "auth": {
    "type": "basic",
    "username": "${IETM_USERNAME}",
    "password": "${IETM_PASSWORD}"
  },
  "testPlan": {
    "id": "987",
    "name": "IT1-System Test"
  },
  "mapping": {
    "strategy": "id",
    "mappings": {
      "login-test": "2218",
      "logout-test": "2219"
    }
  },
  "retry": {
    "maxRetries": 3,
    "retryDelay": 1000
  },
  "logging": {
    "level": "info",
    "file": "logs/ietm-client.log"
  },
  "attachments": {
    "uploadScreenshots": true,
    "uploadVideos": true,
    "uploadLogs": true,
    "maxFileSize": 10485760
  }
}